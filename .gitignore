# ── Virtual environment ───────────────────────────────────────
venv/
env/
.env
.venv/
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ── Model weight files ───────────────────────────────────────
# Large weights stay out of git; the small trained models (~6 MB total) are
# committed so a fresh clone / CI runs the real models instead of fallbacks.
# Phi-3 LLM (~2.2 GB) — download separately; app falls back to template alerts.
# NOTE: gitignore has no inline comments — keep patterns on their own lines.
models/*.gguf
models/*.bin
models/*.safetensors
# (models/*.pt, *.pkl, *.zip ARE committed — small, deterministic, validated)

# ── Data files (download separately — see README.md) ─────────
data/*.txt
data/*.csv
data/*.zip
data/*.gz

# ── Results and outputs ───────────────────────────────────────
# Keep results/ folder structure but ignore large output files
results/*.png
results/*.jpg
results/*.pdf

# ── IDE and OS files ──────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# ── Jupyter notebooks checkpoints ────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Build artifacts ───────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ── pytest cache ─────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
*.jsonl
tensorboard_logs/

# ── llama.cpp build artifacts ─────────────────────────────────
*.so
*.dylib
# MHARS runtime-generated
mhars/share_links.json
mhars/share_tokens.json

# Pre-P1 model backups (local only)
models/backup_pre_p1/

# TorchScript edge artifacts (local build output)
models/edge/
