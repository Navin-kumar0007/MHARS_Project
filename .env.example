# ── MHARS Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and configure for your deployment.
#   cp .env.example .env

# ── API Server ────────────────────────────────────────────────────────────────
MHARS_API_HOST=127.0.0.1
MHARS_API_PORT=8000

# ── Authentication ────────────────────────────────────────────────────────────
# Leave empty to disable auth (development mode).
# Set a strong random key for production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MHARS_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use "*" for development.
MHARS_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Dashboard (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/telemetry

# ── Machine Configuration ────────────────────────────────────────────────────
# Default machine type: 0=CPU, 1=Motor, 2=Server, 3=Engine
MHARS_DEFAULT_MACHINE=1

# ── Sensor Acquisition ───────────────────────────────────────────────────────
# Mode: "simulate" (no hardware), "file" (pre-recorded), "live" (real sensors)
MHARS_SENSOR_MODE=simulate
MHARS_AUDIO_DIR=data/audio
MHARS_IMAGE_DIR=data/thermal

# ── LLM ───────────────────────────────────────────────────────────────────────
# Path to Phi-3 Mini GGUF model. Leave empty to use template fallback.
MHARS_LLM_PATH=models/Phi-3-mini-4k-instruct-q4.gguf
